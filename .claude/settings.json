{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "autoUpdatesChannel": "stable",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(nvidia-smi)",
      "Bash(nvidia-smi *)",
      "Bash(glxinfo *)",
      "Bash(ldd *)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(rm -rf *)",
      "Bash(prime-select *)",
      "Bash(nvidia-settings *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Read(~/.ssh/**)",
      "Read(~/avstack/morai/**/*license*)",
      "Read(./env/**/*secret*)",
      "Read(./env/**/*token*)",
      "Read(./env/**/*key*)",
      "Read(.env)",
      "Read(./secrets/**)"
    ]
  }
}